  "npcs": [
    {
      "id": "cooltrainer_m",
      "name": "Cool Trainer (male) — Miracle Seed giver",
      "x": 19,
      "y": 8,
      "facing": "left",
      "movement": "standing",
      "script_type": "quest",
      "dialogue_summary": "Blocks the player initially (scene SCENE_ROUTE32_COOLTRAINER_M_BLOCKS) if the player lacks the Zephyr Badge. After beating Falkner and receiving the Togepi Egg from Elm's aide, he gives the player the Miracle Seed (boosts Grass-type move power). After that he just offers encouragement.",
      "gives_item": "Miracle Seed",
      "requires": "EVENT_GOT_TOGEPI_EGG_FROM_ELMS_AIDE"
    },
    {
      "id": "roar_tm_guy",
      "name": "Roar TM Man",
      "x": 15,
      "y": 13,
      "facing": "right",
      "movement": "standing",
      "script_type": "quest",
      "dialogue_summary": "Enthusiastically gives the player TM05 (Roar) for free. After receiving it he describes how even Pokemon flee a good roar.",
      "gives_item": "TM05 (Roar)",
      "requires": null,
      "pokecrystal_event": "EVENT_GOT_TM05_ROAR"
    },
    {
      "id": "slowpoke_tail_salesman",
      "name": "Suspicious Fisher (Slowpoke Tail salesman)",
      "x": 7,
      "y": 70,
      "facing": "down",
      "movement": "standing",
      "script_type": "quest_scene",
      "dialogue_summary": "Tries to sell the player a Slowpoke Tail for 1,000,000 yen. The player always declines. This NPC is linked to Team Rocket's Slowpoke Well operation and only appears before that plot is resolved (EVENT_SLOWPOKE_WELL_ROCKETS).",
      "visible_condition": "EVENT_SLOWPOKE_WELL_ROCKETS (must be unresolved)",
      "pokecrystal_scene": "SCENE_ROUTE32_OFFER_SLOWPOKETAIL"
    },
    {
      "id": "frieda_of_friday",
      "name": "Frieda of Friday",
      "x": 12,
      "y": 67,
      "facing": "left",
      "movement": "standing",
      "script_type": "quest",
      "dialogue_summary": "Appears ONLY on Fridays. Introduces herself as Frieda of Friday and gives the player a Poison Barb (held item that boosts Poison-type moves). On other days she is invisible (DISAPPEAR callback).",
      "visible_condition": "VAR_WEEKDAY == FRIDAY",
      "gives_item": "Poison Barb",
      "requires": null,
      "pokecrystal_event": "EVENT_GOT_POISON_BARB_FROM_FRIEDA",
      "pokecrystal_callback": "Route32FriedaCallback"
    }
  ],
