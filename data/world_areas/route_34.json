  "map_callbacks": [
    {
      "type": "MAPCALLBACK_OBJECTS",
      "script": "Route34EggCheckCallback",
      "notes": "On every map load, checks ENGINE_DAY_CARE_MAN_HAS_EGG flag. If true, moves Day Care Man outside (sets EVENT_DAY_CARE_MAN_ON_ROUTE_34, clears EVENT_DAY_CARE_MAN_IN_DAY_CARE). Also checks ENGINE_DAY_CARE_MAN_HAS_MON and ENGINE_DAY_CARE_LADY_HAS_MON to show/hide the exterior Pokemon sprites."
    }
  ],

  "story_events": [
    {
      "order": 1,
      "trigger": "first_pass_through",
      "description": "Player passes through Route 34 on the way from Ilex Forest (south) to Goldenrod City (north). No gate blocking on initial pass.",
      "notes": "Route is accessible after completing the Farfetch'd quest in Ilex Forest."
    },
    {
      "order": 2,
      "trigger": "visit_day_care",
      "description": "Player can deposit up to 2 Pokemon at the Day Care. Pokemon gain 1 EXP per step. Two compatible species may produce an Egg (Odd Egg given on first visit to Day Care interior in Crystal).",
      "notes": "Day Care Man comes outside and chases the player when an Egg is ready."
    },
    {
      "order": 3,
      "trigger": "egg_ready",
      "description": "Day Care Man runs outside with the Egg. Player must accept it (requires empty party slot). Man walks back inside after handoff.",
      "flags_set": ["EVENT_GOT_ODD_EGG (Crystal first visit to Day Care interior)"],
      "items_given": ["Egg (species determined by parent pair)"]
    },
    {
      "order": 4,
      "trigger": "post_hm_surf",
      "description": "After obtaining Surf (HM03), player can access the fenced water area at the route's south-west. Contains Nugget item ball, hidden Rare Candy, and three Cooltrainer F sister trainers (Irene, Jenn, Kate). Kate gives Soft Sand after defeat.",
      "requires": "Surf",
      "items_given": ["Nugget", "Rare Candy (hidden)", "Soft Sand (from Kate)"]
    }
  ],

